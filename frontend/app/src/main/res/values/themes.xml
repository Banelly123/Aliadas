<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Aliadas" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_light</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/purple_primary</item>
        <item name="chipStyle">@style/AliadadChipStyle</item>
        <item name="alertDialogTheme">@style/AliadasAlertDialogTheme</item>
    </style>

    <style name="AliadasAlertDialogTheme" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorAccent">@color/purple_primary</item>
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="buttonBarPositiveButtonStyle">@style/AliadasDialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/AliadasDialogButtonStyle</item>
    </style>

    <style name="AliadasDialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/purple_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AliadadChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/purple_light</item>
        <item name="chipStrokeColor">@color/purple_primary</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="checkedIconTint">@color/purple_primary</item>
    </style>

    <!-- Color selector for nav icons -->
    <style name="NavIconTint">
        <item name="android:state_checked">@color/purple_primary</item>
        <item name="android:state_selected">@color/purple_primary</item>
        <item name="android:state_enabled">@color/text_secondary</item>
    </style>
</resources>
