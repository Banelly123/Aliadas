<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
<!--  ✅ MapView de OSMDroid — no necesita API key  -->
<org.osmdroid.views.MapView android:id="@+id/osm_map" android:layout_width="0dp" android:layout_height="0dp" android:clickable="true" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Barra superior con bienvenida  -->
<LinearLayout android:id="@+id/top_bar" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@drawable/bg_top_bar" android:padding="16dp" android:gravity="center_vertical" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
<ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_aliadas_logo" app:tint="@color/purple_primary"/>
<TextView android:id="@+id/tv_welcome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Hola 💜" android:textSize="16sp" android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium" android:layout_marginStart="12dp"/>
</LinearLayout>
<!--  Botón de pánico centrado abajo  -->
<LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginBottom="80dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
<com.google.android.material.button.MaterialButton android:id="@+id/btn_panic" android:layout_width="160dp" android:layout_height="160dp" android:text="SOS" android:textSize="28sp" android:textColor="@color/white" android:fontFamily="sans-serif-black" app:cornerRadius="80dp" android:backgroundTint="@color/red_panic" app:elevation="12dp" android:stateListAnimator="@null"/>
<TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Botón de pánico" android:textSize="12sp" android:textColor="@color/white" android:layout_marginTop="8dp" android:background="@drawable/bg_label" android:padding="6dp" android:paddingHorizontal="12dp"/>
</LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
